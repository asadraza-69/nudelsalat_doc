#!/usr/bin/env php
<?php

// Find autoload - check vendor first (installed as package), then local (dev)
if (file_exists(__DIR__ . '/vendor/autoload.php')) {
    require __DIR__ . '/vendor/autoload.php';
} elseif (file_exists(__DIR__ . '/autoload.php')) {
    require __DIR__ . '/autoload.php';
} else {
    echo "Error: autoload.php not found. Run 'composer install' first.\n";
    exit(1);
}

use Nudelsalat\Config;
use Nudelsalat\Bootstrap;
use Nudelsalat\Console\Kernel;

// Find config file in project root (where command is run)
$configFile = getcwd() . '/nudelsalat.config.php';

if (!file_exists($configFile)) {
    echo "Error: nudelsalat.config.php not found in project root.\n";
    echo "Please create one in your project root:\n";
    echo "  cp vendor/nudelsalat/migrations/nudelsalat.config.php.example nudelsalat.config.php\n";
    exit(1);
}

try {
    // 1. Load configuration
    $config = Config::load($configFile);

    // 2. Bootstrap services
    $bootstrap = new Bootstrap($config);
    Bootstrap::setInstance($bootstrap);

    // 3. Run Console Kernel
    $kernel = new Kernel($bootstrap);
    $kernel->run($argv);

} catch (\Exception $e) {
    echo "\033[31mNudelsalat Error: " . $e->getMessage() . "\033[0m\n";
    exit(1);
}